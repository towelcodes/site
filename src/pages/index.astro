---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import { BASE_GITHUB } from "astro:env/client";
---

<Layout title="home">
    <div slot="body" class="relative">
        <div class="prose">
            <h2 class="font-pixel">hello!</h2>
            <p class="text-xl font-pixel">
                i'm a <span>17 year old</span> developer from <span
                    >london, england</span
                >.<br />
            </p>
        </div>

        <article class="prose font-pixel">
            <h3>code</h3>
            <p>
                i focus on learning rust, but i can also write typescript,
                kotlin, and various other languages.<br />
                i'm currently working on <strong
                    ><a href={BASE_GITHUB}>this website</a></strong
                >, a <strong>rhythm game</strong>, and whatever else i feel like
            </p>
            <h3>games</h3>
            <p>i like rhythm games</p>
            <div class="flex flex-row gap-12">
                <div>
                    <p>at home, i play:</p>
                    <ul class="mt-0">
                        <li>
                            <a
                                href="https://osu.ppy.sh/users/23581678"
                                class="text-ctp-pink"
                                target="_blank">osu!mania</a
                            >
                        </li>
                        <li>muse dash</li>
                        <li>minecraft</li>
                        <li>celeste</li>
                        <li>unbeatable</li>
                    </ul>
                </div>
                <div>
                    <p>at the arcade, i play:</p>
                    <ul class="mt-0">
                        <li>sdvx</li>
                        <li>museca</li>
                        <li>dancerush</li>
                        <li>iidx</li>
                    </ul>
                </div>
            </div>

            <h3>other</h3>
            <p>
                other things that interest me include:
                <ul class="mt-0">
                    <li>
                        <strong>video editing</strong>; i'm <small
                            >(slowly)</small
                        > learning after effects
                    </li>
                    <li>
                        <strong>japanese</strong>; i'm learning with anki and <a
                            href="https://www.youtube.com/playlist?list=PLg9uYxuZf8x_A-vcqqyOFZu06WlhnypWj"
                            target="_blank">cure dolly</a
                        >
                    </li>
                    <li>
                        <strong>music</strong>; see my <a
                            href="https://last.fm/user/teatowels"
                            class="text-ctp-red"
                            target="_blank">last.fm</a
                        > or <a
                            href="https://listenbrainz.org/user/teatowel/stats/?range=this_month"
                            class="text-ctp-green"
                            target="_blank">listenbrainz</a
                        >
                    </li>
                    <li>
                        <strong>anime and manga</strong>; see my <a
                            href="https://anilist.co/user/teatowel"
                            target="_blank">anilist</a
                        >
                    </li>
                </ul>
            </p>

            <h3>hardware</h3>
            <ul>
                <li>
                    <strong>PC</strong>: Windows 11, Ryzen 5 5600, RTX 3070,
                    32GB (DDR4), 1.5TB
                </li>
                <li>
                    <strong>Dell Precision</strong>: Ubuntu Server, Xeon E5-1630
                    v3, RX 590, 16GB (DDR4), 500GB
                </li>
                <li>
                    <strong>Macbook Pro (2021, 14")</strong>: macOS 26, M1 Pro,
                    16GB (LPDDR5), 512GB
                </li>
                <li>
                    <strong>Raspberry Pi 4</strong>: ARM Cortex-A72 [4 core /
                    1.8Ghz], 4GB (LPDDR4), 64GB
                </li>
                <li>
                    <strong>Synology DS218</strong>: 1.4GHz [2 cores], 2GB
                    (DDR4), 2TB
                </li>
                <li>
                    <strong>iPhone 12 Mini</strong>: A14, iOS 26, 64GB
                </li>
            </ul>
        </article>
    </div>
</Layout>
