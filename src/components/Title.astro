---
import Teatowel from "../assets/typography/teatowels.svg";
import Home from "../assets/typography/home.svg";
import Socials from "../components/Socials.astro";
import { Image } from "astro:assets";

const { title } = Astro.props;
const path = Astro.url.pathname;
const accent = path == "/" ? "ctp-green" : "ctp-sky";
const returnHome = path != "/";
---

<nav class="mt-8 flex items-center justify-center w-full">
    <div class="flex gap-2">
        <Image src={Teatowel} alt="teatowel's" height="44" />
        <Image
            src={Home}
            alt="teatowel's"
            height="44"
            class="drop-shadow-ctp-green drop-shadow-glow"
        />
    </div>
</nav>

<!-- display socials for small displays -->
<div class="md:hidden mt-4 flex justify-center items-center">
    <Socials horizontal small />
</div>
